# ===========================================
# SniperThinkAI - Environment Configuration
# ===========================================

# ----- Database (Neon PostgreSQL) -----
DATABASE_URL="your_neon_database_url"

# ----- Authentication -----
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"

# ----- Cloudflare R2 Storage -----
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# ----- AI APIs -----
# Google Gemini (Prompt Enhancement)
GEMINI_API_KEY=your_gemini_api_key
VEO_API_KEY=your_veo_api_key

# Replicate (AI Photos & Videos)
REPLICATE_API_KEY=your_replicate_api_key

# Runway (Video Generation)
RUNWAY_API_KEY=your_runway_api_key
RUNWAY_API_SECRET=your_runway_api_secret

# Suno (AI Music Generation)
SUNO_API_KEY=your_suno_api_key

# ----- Instagram/Meta Graph API -----
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_REDIRECT_URI=https://your-domain.vercel.app/api/auth/instagram/callback
GRAPH_API_VERSION=v24.0
INSTAGRAM_ACCESS_TOKEN=
